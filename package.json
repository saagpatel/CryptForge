{
  "name": "cryptforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <26",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "dev:lean": "./scripts/lean-dev.sh",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "tauri": "node ./node_modules/@tauri-apps/cli/tauri.js",
    "clean:heavy": "./scripts/cleanup-heavy.sh",
    "clean:full": "./scripts/cleanup-full.sh",
    "doctor:env": "node scripts/doctor-env.mjs",
    "verify:preflight": "npm run doctor:env",
    "verify:frontend:test": "npm run test -- --run",
    "verify:frontend": "npm run build && npm run verify:frontend:test",
    "verify:rust:test": "node scripts/run-in-safe-cwd.mjs -- cargo test --manifest-path src-tauri/Cargo.toml",
    "verify:rust:fmt": "node scripts/run-in-safe-cwd.mjs -- cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "verify:rust:clippy": "node scripts/run-in-safe-cwd.mjs -- cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "verify:rust": "npm run verify:rust:test && npm run verify:rust:fmt && npm run verify:rust:clippy",
    "verify": "npm run verify:preflight && npm run verify:frontend && npm run verify:rust",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "prepare": "node scripts/setup-husky.mjs",
    "commit": "node ./node_modules/commitizen/bin/git-cz",
    "commitlint": "node ./node_modules/@commitlint/cli/lib/cli.js",
    "git:guard:branch": "bash scripts/git/guard-branch.sh",
    "git:guard:no-main-push": "bash scripts/git/guard-no-main-push.sh",
    "git:guard:atomic": "bash scripts/git/guard-atomic.sh",
    "git:guard:generated": "bash scripts/git/guard-generated.sh",
    "git:guard:large-files": "bash scripts/git/guard-large-files.sh",
    "git:guard:secrets": "bash scripts/git/guard-secrets.sh",
    "git:guard:all": "npm run git:guard:branch && npm run git:guard:atomic && npm run git:guard:generated && npm run git:guard:large-files && npm run git:guard:secrets",
    "git:commit:propose": "node scripts/git/propose-commit-message.mjs",
    "git:session:save": "bash scripts/git/session-save.sh",
    "git:session:resume": "bash scripts/git/session-resume.sh",
    "pr:notes": "bash scripts/git/generate-pr-notes.sh",
    "perf:bundle": "node scripts/perf/bundle-report.mjs",
    "perf:build": "node scripts/perf/measure-build-time.mjs",
    "perf:assets": "bash scripts/perf/check-assets.sh",
    "perf:memory": "node --expose-gc scripts/perf/memory-smoke.mjs",
    "perf:lhci": "node ./node_modules/@lhci/cli/src/cli.js autorun --config=lighthouserc.json",
    "perf:lhci:prod": "node ./node_modules/@lhci/cli/src/cli.js autorun --config=.lighthouserc.production.json",
    "perf:summary": "node scripts/perf/summarize.mjs",
    "lint-staged": "node ./node_modules/lint-staged/bin/lint-staged.js"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "@lhci/cli": "^0.15.1",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "vitest": "^3.2.4"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  }
}
